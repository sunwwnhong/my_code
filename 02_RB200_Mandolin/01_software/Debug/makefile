"Servo_Alfa.out" 


# All Target
all: $(OBJS) $(CMD_SRCS) $(LIB_SRCS) $(GEN_CMDS)
	@$(MAKE) --no-print-directory -Onone "Servo_Alfa.out"

# Tool invocations
Servo_Alfa.out: $(OBJS) $(CMD_SRCS) $(LIB_SRCS) $(GEN_CMDS)
	@echo 'Building target: "$@"'
	@echo 'Invoking: C2000 Linker'
	@echo 'Flags: -v28 -ml -mt --cla_support=cla2 --float_support=fpu64 --tmu_support=tmu1 --vcu_support=vcrc -O4 --opt_for_speed=5 --fp_mode=relaxed --advice:performance=all --define=ccs_c2k --define=MotA_En --define=_F2838X --define=ETHERCAT_STACK --define=CPU1 --define=CPU2_En -g --diag_warning=225 --diag_wrap=off --display_error_number --abi=eabi -z -m"Servo_Alfa.map" --stack_size=0x200 --warn_sections -i"C:/ti/ccs1260/ccs/tools/compiler/ti-cgt-c2000_22.6.1.LTS/lib" -i"C:/ti/ccs1260/ccs/tools/compiler/ti-cgt-c2000_22.6.1.LTS/include" --reread_libs --diag_wrap=off --display_error_number --xml_link_info="Servo_Alfa_linkInfo.xml" --entry_point=_c_int00 --rom_model'
	$(shell echo -v28 -ml -mt --cla_support=cla2 --float_support=fpu64 --tmu_support=tmu1 --vcu_support=vcrc -O4 --opt_for_speed=5 --fp_mode=relaxed --advice:performance=all --define=ccs_c2k --define=MotA_En --define=_F2838X --define=ETHERCAT_STACK --define=CPU1 --define=CPU2_En -g --diag_warning=225 --diag_wrap=off --display_error_number --abi=eabi -z -m"Servo_Alfa.map" --stack_size=0x200 --warn_sections -i"C:/ti/ccs1260/ccs/tools/compiler/ti-cgt-c2000_22.6.1.LTS/lib" -i"C:/ti/ccs1260/ccs/tools/compiler/ti-cgt-c2000_22.6.1.LTS/include" --reread_libs --diag_wrap=off --display_error_number --xml_link_info="Servo_Alfa_linkInfo.xml" --entry_point=_c_int00 --rom_model > "ccsLinker.opt")
	$(shell type "ccsObjs.opt" >> "ccsLinker.opt")
	"C:/ti/ccs1260/ccs/tools/compiler/ti-cgt-c2000_22.6.1.LTS/bin/cl2000" -@"ccsLinker.opt" -o "Servo_Alfa.out"
	@echo 'Finished building target: "$@"'
	@echo ' '

